class Solution {
    public int maxDistance(int[] colors) {
        int n = colors.length;
        int maxDist = 0;
        for(int i = 0; i < n; i++){
            int dist = 0;
            for(int j = i+1; j < n; j++){
                if(colors[i] != colors[j]){
                    dist = Math.max(dist, j - i);
                }
            }
            maxDist = Math.max(maxDist, dist);
        }

        return maxDist;
    }
}
